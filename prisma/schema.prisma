generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Booking {
  id        String   @id @default(uuid())
  name      String
  email     String
  date      DateTime
  timeSlot  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
