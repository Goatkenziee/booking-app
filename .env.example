# Database (Neon/Postgres) — auto-injected by managed database on Resources → Databases
# DATABASE_URL=postgresql://...
# DIRECT_URL=postgresql://...

# Email (Resend) — required for real email sending; app falls back to mock if unset
RESEND_API_KEY=re_...
EMAIL_FROM=bookings@yourdomain.com

# App
NODE_ENV=production
